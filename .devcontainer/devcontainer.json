{
  "name": "Rust DevContainer",
  "image": "mcr.microsoft.com/devcontainers/rust:1-1-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "postCreateCommand": "rustup update stable && rustup default stable && rustup component add rustfmt clippy",
  "postStartCommand": "sudo install -d -m 2775 -o vscode -g vscode /workspaces/git-secret-vault.worktrees",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/copilot-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "25",
      "nodeGypDependencies": true,
      "installYarnUsingApt": true,
      "pnpmVersion": "latest",
      "nvmVersion": "latest"
    }
  }
}
