{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "noEmit": true,
    "strict": false
  },
  "include": ["scripts/**/*.ts"],
  "ts.nodeArgs": ["--no-warnings"]
}
